{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src", "skills", "agents", "workflow", "vitest.config.ts"],
  "exclude": ["node_modules", "**/fixtures/**"]
}
